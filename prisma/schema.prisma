generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  //directUrl = env("DIRECT_URL")
}


model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  password            String
  passwordResetVersion Int     @default(0)
  sessionVersion      Int      @default(0)
  role                String   @default("member")
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)
  files      UserFile[]
  projects   Project[]
  coOwnedProjects ProjectCoOwner[] @relation("ProjectCoOwnerAdmin")
  assignedProjectCoOwners ProjectCoOwner[] @relation("ProjectCoOwnerAssigner")
  projectReports ProjectReport[]
  documentIdempotencyKeys DocumentIdempotency[]
  authSessions AuthSession[]
  notificationEventsAuthored NotificationEvent[] @relation("NotificationActor")
  notificationRecipients NotificationRecipient[] @relation("NotificationRecipientUser")

  @@index([created_at])
  @@index([name])
}

model AuthSession {
  id               BigInt    @id @default(autoincrement())
  userId           Int       @map("user_id")
  sessionId        String    @unique @map("session_id") @db.VarChar(64)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(128)
  familyId         String    @map("family_id") @db.VarChar(64)
  sessionVersion   Int       @default(0) @map("session_version")
  expiresAt        DateTime  @map("expires_at") @db.Timestamp(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamp(6)
  rotatedAt        DateTime? @map("rotated_at") @db.Timestamp(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamp(6)
  ip               String?   @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @updatedAt @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([familyId])
  @@index([userId, sessionVersion])
  @@index([revokedAt])
  @@map("auth_sessions")
}


model Program {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)

  projects   Project[]

  @@index([sortOrder])
  @@index([isActive, sortOrder])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  status      String   @default("กำลังดำเนินการ")
  statusNote  String?  @db.Text
  allowCoOwners Boolean @default(false)

  programId   Int?

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(6)

  userId Int

  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  coOwners ProjectCoOwner[]
  files UserFile[]
  reports ProjectReport[]
  notificationEvents NotificationEvent[]

  @@index([programId])
  @@index([programId, created_at])
  @@index([userId])
  @@unique([userId, name])
  @@index([userId, created_at])
  @@index([status, created_at])
  @@index([created_at])
  @@index([deletedAt])
  @@index([name])
}

model ProjectCoOwner {
  id          Int      @id @default(autoincrement())
  projectId   Int
  adminUserId Int
  assignedById Int
  created_at  DateTime @default(now()) @db.Timestamp(6)

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adminUser  User    @relation("ProjectCoOwnerAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("ProjectCoOwnerAssigner", fields: [assignedById], references: [id], onDelete: Cascade)

  @@unique([projectId, adminUserId])
  @@index([projectId])
  @@index([adminUserId])
  @@index([assignedById])
}


model UserFile {
  id               Int @id @default(autoincrement())
  originalFileName String @db.VarChar(255)
  storagePath      String
  fileExtension    String
  downloadStatus   String @default("pending") 
  downloadedAt     DateTime? 
  deletionStatus   String @default("active") @map("deletion_status") @db.VarChar(16)

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)

  // Foreign keys
  userId Int
  projectId Int?  

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachmentFiles AttachmentFile[] // ความสัมพันธ์กับไฟล์แนบ
  projectReports ProjectReport[]

  @@index([userId])
  @@index([projectId])
  @@index([projectId, created_at])
  @@index([created_at])
  @@index([deletionStatus, created_at])
}

model ProjectReport {
  id         Int    @id @default(autoincrement())
  reportType String @db.VarChar(50)
  status     String @default("รอตรวจสอบ") @db.VarChar(50)
  note       String? @db.Text
  adminNote  String? @db.Text

  submittedAt DateTime  @default(now()) @db.Timestamp(6)
  reviewedAt  DateTime? @db.Timestamp(6)
  reviewedBy  Int?

  userId    Int
  projectId Int
  fileId    Int

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    UserFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  notificationEvents NotificationEvent[]

  @@index([projectId, submittedAt])
  @@index([userId, submittedAt])
  @@index([status, submittedAt])
  @@index([fileId])
}


model AttachmentFile {
  id       Int    @id @default(autoincrement())
  fileName String
  filePath String
  fileSize Int
  mimeType String

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)

  // Foreign key linking to the UserFile model
  userFileId Int

  // Relationships
  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)

  @@index([userFileId])
}


model ContractCounter {
  id            Int      @id @default(autoincrement())
  contractType  String
  buddhistYear  Int
  currentNumber Int      @default(1) 
  
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)

  @@unique([contractType, buddhistYear])
}

model DocumentIdempotency {
  id             BigInt   @id @default(autoincrement())
  userId         Int
  documentType   String   @map("document_type")
  idempotencyKey String   @map("idempotency_key")
  status         String   @default("processing")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  errorMessage   String?  @map("error_message")
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)
  completed_at   DateTime? @map("completed_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentType, idempotencyKey])
  @@index([userId, created_at])
  @@index([status, created_at])
  @@map("document_idempotency")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  action      String
  outcome     String   @default("success")
  actorUserId Int?     @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  ip          String?
  userAgent   String?  @map("user_agent")
  requestId   String?  @map("request_id")
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([created_at])
  @@index([action, created_at])
  @@index([actorUserId, created_at])
  @@index([targetType, targetId, created_at])
  @@index([requestId])
  @@map("audit_logs")
}

model NotificationEvent {
  id              BigInt   @id @default(autoincrement())
  type            String   @db.VarChar(64)
  actorUserId     Int?
  projectId       Int?
  projectReportId Int?
  title           String   @db.VarChar(160)
  message         String   @db.VarChar(500)
  actionUrl       String?  @db.VarChar(300)
  metadata        Json?
  dedupeKey       String?  @unique @db.VarChar(191)
  created_at      DateTime @default(now()) @db.Timestamp(6)

  actor        User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectReport ProjectReport? @relation(fields: [projectReportId], references: [id], onDelete: SetNull)
  recipients   NotificationRecipient[]

  @@index([type, created_at])
  @@index([projectId, created_at])
  @@index([projectReportId, created_at])
  @@index([actorUserId, created_at])
}

model NotificationRecipient {
  id              BigInt    @id @default(autoincrement())
  eventId         BigInt
  recipientUserId Int
  audience        String    @default("user") @db.VarChar(16)
  seenAt          DateTime? @db.Timestamp(6)
  readAt          DateTime? @db.Timestamp(6)
  archivedAt      DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)

  event     NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipient User @relation("NotificationRecipientUser", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, recipientUserId])
  @@index([recipientUserId, audience, readAt, created_at], map: "NotifRec_user_aud_read_created_idx")
  @@index([recipientUserId, audience, archivedAt, created_at], map: "NotifRec_user_aud_arch_created_idx")
  @@index([recipientUserId, readAt, created_at])
  @@index([recipientUserId, archivedAt, created_at])
  @@index([eventId])
}
