generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  //directUrl = env("DIRECT_URL")
}


model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  password            String
  passwordResetVersion Int     @default(0)
  sessionVersion      Int      @default(0)
  role                String   @default("member")
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  files      UserFile[]
  projects   Project[]
  coOwnedProjects ProjectCoOwner[] @relation("ProjectCoOwnerAdmin")
  assignedProjectCoOwners ProjectCoOwner[] @relation("ProjectCoOwnerAssigner")
  projectReports ProjectReport[]
  documentIdempotencyKeys DocumentIdempotency[]

  @@index([created_at])
  @@index([name])
}


model Program {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  projects   Project[]

  @@index([sortOrder])
  @@index([isActive, sortOrder])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  status      String   @default("กำลังดำเนินการ")
  statusNote  String?  @db.Text
  allowCoOwners Boolean @default(false)

  programId   Int?

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(6)

  userId Int

  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  coOwners ProjectCoOwner[]
  files UserFile[]
  reports ProjectReport[]

  @@index([programId])
  @@index([programId, created_at])
  @@index([userId])
  @@unique([userId, name])
  @@index([userId, created_at])
  @@index([status, created_at])
  @@index([created_at])
  @@index([deletedAt])
  @@index([name])
}

model ProjectCoOwner {
  id          Int      @id @default(autoincrement())
  projectId   Int
  adminUserId Int
  assignedById Int
  created_at  DateTime @default(now()) @db.Timestamp(6)

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adminUser  User    @relation("ProjectCoOwnerAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("ProjectCoOwnerAssigner", fields: [assignedById], references: [id], onDelete: Cascade)

  @@unique([projectId, adminUserId])
  @@index([projectId])
  @@index([adminUserId])
  @@index([assignedById])
}


model UserFile {
  id               Int @id @default(autoincrement())
  originalFileName String @db.VarChar(255)
  storagePath      String
  fileExtension    String
  downloadStatus   String @default("pending") 
  downloadedAt     DateTime? 

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  // Foreign keys
  userId Int
  projectId Int?  

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachmentFiles AttachmentFile[] // ความสัมพันธ์กับไฟล์แนบ
  projectReports ProjectReport[]

  @@index([userId])
  @@index([projectId])
  @@index([projectId, created_at])
  @@index([created_at])
}

model ProjectReport {
  id         Int    @id @default(autoincrement())
  reportType String @db.VarChar(50)
  status     String @default("รอตรวจสอบ") @db.VarChar(50)
  note       String? @db.Text
  adminNote  String? @db.Text

  submittedAt DateTime  @default(now()) @db.Timestamp(6)
  reviewedAt  DateTime? @db.Timestamp(6)
  reviewedBy  Int?

  userId    Int
  projectId Int
  fileId    Int

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    UserFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId, submittedAt])
  @@index([userId, submittedAt])
  @@index([status, submittedAt])
  @@index([fileId])
}


model AttachmentFile {
  id       Int    @id @default(autoincrement())
  fileName String
  filePath String
  fileSize Int
  mimeType String

  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  // Foreign key linking to the UserFile model
  userFileId Int

  // Relationships
  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)

  @@index([userFileId])
}


model ContractCounter {
  id            Int      @id @default(autoincrement())
  contractType  String
  buddhistYear  Int
  currentNumber Int      @default(1) 
  
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@unique([contractType, buddhistYear])
}

model DocumentIdempotency {
  id             BigInt   @id @default(autoincrement())
  userId         Int
  documentType   String   @map("document_type")
  idempotencyKey String   @map("idempotency_key")
  status         String   @default("processing")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  errorMessage   String?  @map("error_message")
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)
  completed_at   DateTime? @map("completed_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentType, idempotencyKey])
  @@index([userId, created_at])
  @@index([status, created_at])
  @@map("document_idempotency")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  action      String
  outcome     String   @default("success")
  actorUserId Int?     @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  ip          String?
  userAgent   String?  @map("user_agent")
  requestId   String?  @map("request_id")
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([created_at])
  @@index([action, created_at])
  @@index([actorUserId, created_at])
  @@index([targetType, targetId, created_at])
  @@index([requestId])
  @@map("audit_logs")
}
