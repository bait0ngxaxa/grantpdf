# Application
NODE_ENV=development
PORT=3000
AUTH_URL=http://localhost:3000

# สร้าง secret แยกกันด้วย: openssl rand -base64 48
AUTH_SECRET=replace-with-a-random-secret
AUTH_ACCESS_TOKEN_SECRET=replace-with-a-different-random-secret
PASSRESET_TOKEN_SECRET=replace-with-a-different-random-secret
FILE_TOKEN_SECRET=replace-with-a-different-random-secret

# MySQL: port 3307 คือ port ที่ docker-compose.yml เปิดให้ host
DATABASE_URL=mysql://grant_user:replace-db-password@127.0.0.1:3307/grant_online
MYSQL_ROOT_PASSWORD=replace-root-password
MYSQL_DATABASE=grant_online
MYSQL_USER=grant_user
MYSQL_PASSWORD=replace-db-password

# Redis ใช้สำหรับ cache, session cache และ distributed rate limit
REDIS_URL=redis://127.0.0.1:6379

# SMTP สำหรับอีเมลรีเซ็ตรหัสผ่าน
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-smtp-password

# งาน reconciliation การลบไฟล์
FILE_DELETION_RECONCILIATION_ENABLED=true
FILE_DELETION_RECONCILIATION_SECRET=replace-with-a-different-random-secret
